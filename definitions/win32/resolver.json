{
  "schemaVersion": "0.1.0",
  "module": "resolver",
  "description": "Resolver APIs tracked as definition-only metadata until returned-pointer instrumentation is separately designed and verified.",
  "apis": [
    {
      "module": "KERNEL32.dll",
      "name": "GetProcAddress",
      "family": "resolver",
      "category": "dynamic_symbol_lookup",
      "risk": "high",
      "hookPolicy": "deferred",
      "coverageStatus": "definition_only",
      "architectures": ["x86", "x64"],
      "callingConvention": "stdcall",
      "returnType": "FARPROC",
      "errorSource": "GetLastError",
      "success": { "returnNotEqual": "NULL" },
      "failure": { "returnEqual": "NULL" },
      "parameters": [
        { "name": "hModule", "type": "HMODULE", "direction": "in", "decode": "module_handle" },
        { "name": "lpProcName", "type": "LPCSTR", "direction": "in", "decode": "proc_name_or_ordinal", "maxBytes": 512 }
      ]
    },
    {
      "module": "NTDLL.dll",
      "name": "LdrGetProcedureAddress",
      "family": "resolver",
      "category": "dynamic_symbol_lookup_nt",
      "risk": "high",
      "hookPolicy": "deferred",
      "coverageStatus": "definition_only",
      "architectures": ["x86", "x64"],
      "callingConvention": "ntapi",
      "returnType": "NTSTATUS",
      "errorSource": "return_ntstatus",
      "success": { "ntSuccess": true },
      "failure": { "ntSuccess": false },
      "parameters": [
        { "name": "ModuleHandle", "type": "HMODULE", "direction": "in", "decode": "module_handle" },
        { "name": "FunctionName", "type": "PANSI_STRING", "direction": "in", "decode": "ansi_string_struct", "nullable": true, "maxBytes": 512 },
        { "name": "Ordinal", "type": "WORD", "direction": "in", "decode": "byte_count" },
        { "name": "FunctionAddress", "type": "PVOID*", "direction": "out", "decode": "function_pointer_pointer", "captureTiming": "post" }
      ]
    }
  ]
}
