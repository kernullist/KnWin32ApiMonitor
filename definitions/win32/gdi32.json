        { "name": "hdc", "type": "HDC", "direction": "in", "decode": "hdc_handle", "nullable": true }
      ]
    },
    {
      "module": "GDI32.dll",
      "name": "GetDeviceCaps",
      "family": "gdi",
      "category": "gdi_device_cap_query",
      "risk": "low",
      "hookPolicy": "iat",
      "coverageStatus": "smoke_verified",
