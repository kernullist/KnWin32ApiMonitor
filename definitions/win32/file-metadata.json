{
  "schemaVersion": "0.1.0",
  "module": "file-metadata",
  "description": "Wave 3 low-payload current-process KERNEL32 file metadata hooks.",
  "apis": [
    {
      "module": "KERNEL32.dll",
      "name": "GetFileSizeEx",
      "family": "file",
      "category": "file_size_query",
      "risk": "low",
      "hookPolicy": "iat",
      "coverageStatus": "smoke_verified",
      "architectures": ["x86", "x64"],
      "callingConvention": "stdcall",
      "returnType": "BOOL",
      "errorSource": "GetLastError",
      "success": { "returnNotEqual": 0 },
      "failure": { "returnEqual": 0 },
      "parameters": [
        { "name": "hFile", "type": "HANDLE", "direction": "in", "decode": "handle" },
        { "name": "lpFileSize", "type": "PLARGE_INTEGER", "direction": "out", "decode": "file_size_pointer", "captureTiming": "post" }
      ]
    },
    {
      "module": "KERNEL32.dll",
      "name": "GetFileTime",
      "family": "file",
      "category": "file_time_query",
      "risk": "low",
      "hookPolicy": "iat",
      "coverageStatus": "smoke_verified",
      "architectures": ["x86", "x64"],
      "callingConvention": "stdcall",
      "returnType": "BOOL",
      "errorSource": "GetLastError",
      "success": { "returnNotEqual": 0 },
      "failure": { "returnEqual": 0 },
      "parameters": [
        { "name": "hFile", "type": "HANDLE", "direction": "in", "decode": "handle" },
        { "name": "lpCreationTime", "type": "LPFILETIME", "direction": "out", "decode": "file_time_pointer", "captureTiming": "post", "nullable": true },
        { "name": "lpLastAccessTime", "type": "LPFILETIME", "direction": "out", "decode": "file_time_pointer", "captureTiming": "post", "nullable": true },
        { "name": "lpLastWriteTime", "type": "LPFILETIME", "direction": "out", "decode": "file_time_pointer", "captureTiming": "post", "nullable": true }
      ]
    },
    {
      "module": "KERNEL32.dll",
      "name": "GetFileInformationByHandle",
      "family": "file",
      "category": "file_information_query",
      "risk": "low",
      "hookPolicy": "iat",
      "coverageStatus": "smoke_verified",
      "architectures": ["x86", "x64"],
      "callingConvention": "stdcall",
      "returnType": "BOOL",
      "errorSource": "GetLastError",
      "success": { "returnNotEqual": 0 },
      "failure": { "returnEqual": 0 },
      "parameters": [
        { "name": "hFile", "type": "HANDLE", "direction": "in", "decode": "handle" },
        { "name": "lpFileInformation", "type": "LPBY_HANDLE_FILE_INFORMATION", "direction": "out", "decode": "by_handle_file_information_pointer", "captureTiming": "post" }
      ]
    }
  ]
}
