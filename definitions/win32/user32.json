      "name": "GetSystemMetrics",
      "family": "ui",
      "category": "user_system_metric",
      "risk": "low",
      "hookPolicy": "iat",
      "coverageStatus": "smoke_verified",
      "architectures": ["x86", "x64"],
      "callingConvention": "stdcall",
      "returnType": "int",
      "errorSource": "none",
      "success": { "always": true },
      "failure": {},
      "parameters": [
        { "name": "nIndex", "type": "int", "direction": "in", "decode": "system_metric_index" }
      ]
    },
    {
