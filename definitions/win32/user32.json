      "coverageStatus": "smoke_verified",
      "architectures": ["x86", "x64"],
      "callingConvention": "stdcall",
      "returnType": "HWND",
      "errorSource": "none",
      "success": { "always": true },
      "failure": {},
      "parameters": []
    },
    {
      "module": "USER32.dll",
      "name": "GetForegroundWindow",
      "family": "ui",
      "category": "window_handle_query",
      "risk": "low",
      "hookPolicy": "iat",
      "coverageStatus": "smoke_verified",
      "architectures": ["x86", "x64"],
      "callingConvention": "stdcall",
      "returnType": "HWND",
