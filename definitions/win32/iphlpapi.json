{
  "schemaVersion": "0.1.0",
  "module": "iphlpapi",
  "description": "Wave 4 metadata for IP helper adapter and interface metadata APIs, with selected pointer-only interface-entry query coverage.",
  "apis": [
    {
      "module": "IPHLPAPI.dll",
      "name": "GetAdaptersAddresses",
      "family": "network-metadata",
      "category": "adapter_addresses_query",
      "risk": "medium",
      "hookPolicy": "definition_only",
      "coverageStatus": "definition_only",
      "architectures": ["x86", "x64"],
      "callingConvention": "stdcall",
      "returnType": "ULONG",
      "errorSource": "none",
      "success": { "returnEqual": "ERROR_SUCCESS" },
      "failure": { "returnNotEqual": "ERROR_SUCCESS" },
      "parameters": [
        { "name": "Family", "type": "ULONG", "direction": "in", "decode": "dword_value" },
        { "name": "Flags", "type": "ULONG", "direction": "in", "decode": "dword_value" },
        { "name": "Reserved", "type": "PVOID", "direction": "in", "decode": "pointer", "nullable": true },
        { "name": "AdapterAddresses", "type": "PIP_ADAPTER_ADDRESSES", "direction": "out", "decode": "pointer", "nullable": true, "captureTiming": "post" },
        { "name": "SizePointer", "type": "PULONG", "direction": "inout", "decode": "dword_pointer", "captureTiming": "pre_post" }
      ]
    },
    {
      "module": "IPHLPAPI.dll",
      "name": "GetIfEntry2",
      "family": "network-metadata",
      "category": "interface_entry_query",
      "risk": "medium",
      "hookPolicy": "iat",
      "coverageStatus": "smoke_verified",
      "architectures": ["x86", "x64"],
      "callingConvention": "stdcall",
      "returnType": "NETIO_STATUS",
      "errorSource": "none",
      "success": { "returnEqual": "NO_ERROR" },
      "failure": { "returnNotEqual": "NO_ERROR" },
      "parameters": [
        { "name": "Row", "type": "PMIB_IF_ROW2", "direction": "inout", "decode": "pointer", "captureTiming": "pre_post" }
      ]
    }
  ]
}
