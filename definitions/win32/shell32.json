{
  "schemaVersion": "0.1.0",
  "module": "shell32",
  "description": "Wave 3 low-payload Shell known-folder metadata hooks for allowlisted system folder path queries.",
  "apis": [
    {
      "module": "SHELL32.dll",
      "name": "SHGetKnownFolderPath",
      "family": "shell",
      "category": "known_folder_path_query",
      "risk": "low",
      "hookPolicy": "iat",
      "coverageStatus": "smoke_verified",
      "architectures": ["x86", "x64"],
      "callingConvention": "stdcall",
      "returnType": "HRESULT",
      "errorSource": "HRESULT",
      "success": { "returnEqual": "S_OK" },
      "failure": { "returnNotEqual": "S_OK" },
      "parameters": [
        { "name": "rfid", "type": "REFKNOWNFOLDERID", "direction": "in", "decode": "known_folder_id_pointer" },
        { "name": "dwFlags", "type": "DWORD", "direction": "in", "decode": "dword_value" },
        { "name": "hToken", "type": "HANDLE", "direction": "in", "decode": "handle", "nullable": true },
        { "name": "ppszPath", "type": "PWSTR*", "direction": "out", "decode": "shell_folder_path_pointer_pointer", "nullable": true, "captureTiming": "post" }
      ]
    },
    {
      "module": "SHELL32.dll",
      "name": "SHGetSpecialFolderPathW",
      "family": "shell",
      "category": "special_folder_path_query",
      "risk": "low",
      "hookPolicy": "iat",
      "coverageStatus": "smoke_verified",
      "architectures": ["x86", "x64"],
      "callingConvention": "stdcall",
      "returnType": "BOOL",
      "errorSource": "GetLastError",
      "success": { "returnNotEqual": "FALSE" },
      "failure": { "returnEqual": "FALSE" },
      "parameters": [
        { "name": "hwnd", "type": "HWND", "direction": "in", "decode": "hwnd_handle", "nullable": true },
        { "name": "pszPath", "type": "LPWSTR", "direction": "out", "decode": "shell_folder_path_pointer", "nullable": true, "captureTiming": "post" },
        { "name": "csidl", "type": "int", "direction": "in", "decode": "csidl_value" },
        { "name": "fCreate", "type": "BOOL", "direction": "in", "decode": "dword_value" }
      ]
    }
  ]
}
