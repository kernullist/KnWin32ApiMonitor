#include <winver.h>

VS_VERSION_INFO VERSIONINFO
 FILEVERSION @KNMON_VERSION_COMMA@
 PRODUCTVERSION @KNMON_VERSION_COMMA@
 FILEFLAGSMASK 0x3fL
#ifdef _DEBUG
 FILEFLAGS 0x1L
#else
 FILEFLAGS 0x0L
#endif
 FILEOS 0x40004L
 FILETYPE @KNMON_RESOURCE_FILE_TYPE@
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "@KNMON_COMPANY_NAME@\0"
            VALUE "FileDescription", "@KNMON_RESOURCE_FILE_DESCRIPTION@\0"
            VALUE "FileVersion", "@KNMON_VERSION_STRING@\0"
            VALUE "InternalName", "@KNMON_RESOURCE_INTERNAL_NAME@\0"
            VALUE "OriginalFilename", "@KNMON_RESOURCE_ORIGINAL_FILENAME@\0"
            VALUE "ProductName", "@KNMON_PRODUCT_NAME@\0"
            VALUE "ProductVersion", "@KNMON_VERSION_STRING@\0"
            VALUE "LegalCopyright", "@KNMON_COPYRIGHT@\0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
