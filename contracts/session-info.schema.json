{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kernullist.local/knmon/session-info.schema.json",
  "title": "KnMonSessionInfo",
  "type": "object",
  "required": [
    "schemaVersion",
    "success",
    "sessionId",
    "sessionPath",
    "createdUtc",
    "traceEventCount",
    "agentEventCount",
    "auditEventCount",
    "droppedEvents",
    "win32ErrorCode",
    "message",
    "validationErrors"
  ],
  "properties": {
    "schemaVersion": { "type": "string" },
    "success": { "type": "boolean" },
    "format": { "type": "string" },
    "sessionId": { "type": "string" },
    "sessionPath": { "type": "string" },
    "createdUtc": { "type": "string" },
    "finalized": { "type": "boolean" },
    "traceEventCount": { "type": "integer", "minimum": 0 },
    "agentEventCount": { "type": "integer", "minimum": 0 },
    "auditEventCount": { "type": "integer", "minimum": 0 },
    "droppedEvents": { "type": "integer", "minimum": 0 },
    "transportDroppedEvents": { "type": "integer", "minimum": 0 },
    "hostDroppedBatches": { "type": "integer", "minimum": 0 },
    "chunkCount": { "type": "integer", "minimum": 0 },
    "lastBatchSequence": { "type": "integer", "minimum": 0 },
    "lastRecordSequence": { "type": "integer", "minimum": 0 },
    "writerState": { "type": "string" },
    "win32ErrorCode": { "type": "integer", "minimum": 0 },
    "message": { "type": "string" },
    "validationErrors": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
