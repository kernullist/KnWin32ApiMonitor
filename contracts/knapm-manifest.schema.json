{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kernullist.local/knmon/knapm-manifest.schema.json",
  "title": "KnMonKnapmManifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "format",
    "formatVersion",
    "sessionId",
    "operationId",
    "createdUtc",
    "updatedUtc",
    "finalizedUtc",
    "finalized",
    "source",
    "backendMode",
    "captureMode",
    "injectionMethod",
    "target",
    "agent",
    "session",
    "eventCounts",
    "droppedEvents",
    "transportDroppedEvents",
    "hostDroppedBatches",
    "chunkCount",
    "lastBatchSequence",
    "lastRecordSequence",
    "writerState",
    "files"
  ],
  "properties": {
    "schemaVersion": { "type": "string" },
    "format": { "const": "knapm" },
    "formatVersion": { "type": "string" },
    "sessionId": { "type": "string", "minLength": 1 },
    "operationId": { "type": "string", "minLength": 1 },
    "createdUtc": { "type": "string" },
    "updatedUtc": { "type": "string" },
    "finalizedUtc": { "type": "string" },
    "finalized": { "type": "boolean" },
    "source": { "const": "knmon-native-helper attach-session" },
    "backendMode": { "enum": ["native-capture"] },
    "captureMode": { "enum": ["bounded-native-attach"] },
    "injectionMethod": { "enum": ["remote LoadLibraryW"] },
    "target": {
      "type": "object",
      "required": ["path", "pid", "tid", "architecture"],
      "properties": {
        "path": { "type": "string" },
        "pid": { "type": "integer", "minimum": 0 },
        "tid": { "type": "integer", "minimum": 0 },
        "architecture": { "enum": ["x86", "x64"] }
      }
    },
    "agent": {
      "type": "object",
      "required": ["path", "architecture", "version"],
      "properties": {
        "path": { "type": "string" },
        "architecture": { "enum": ["x86", "x64"] },
        "version": { "type": "string" }
      }
    },
    "session": { "$ref": "native-session.schema.json" },
    "eventCounts": {
      "type": "object",
      "required": ["audit", "agentEvents", "traceEvents", "capturedEvents"],
      "properties": {
        "audit": { "type": "integer", "minimum": 0 },
        "agentEvents": { "type": "integer", "minimum": 0 },
        "traceEvents": { "type": "integer", "minimum": 0 },
        "capturedEvents": { "type": "integer", "minimum": 0 }
      }
    },
    "droppedEvents": { "type": "integer", "minimum": 0 },
    "transportDroppedEvents": { "type": "integer", "minimum": 0 },
    "hostDroppedBatches": { "type": "integer", "minimum": 0 },
    "chunkCount": { "type": "integer", "minimum": 0 },
    "lastBatchSequence": { "type": "integer", "minimum": 0 },
    "lastRecordSequence": { "type": "integer", "minimum": 0 },
    "writerState": { "enum": ["created", "writing", "partial", "finalized", "failed", "stale", "recovery_required"] },
    "owner": {
      "type": "object",
      "required": [
        "ownerKind",
        "hostProcessId",
        "helperProcessId",
        "writerProcessId",
        "writerInstanceId",
        "writerGeneration",
        "startedUtc",
        "updatedUtc",
        "heartbeatUtc",
        "leaseTimeoutMs",
        "leaseExpiresUtc"
      ],
      "properties": {
        "ownerKind": { "enum": ["bounded-helper", "persistent-daemon"] },
        "hostProcessId": { "type": "integer", "minimum": 1 },
        "helperProcessId": { "type": "integer", "minimum": 1 },
        "writerProcessId": { "type": "integer", "minimum": 1 },
        "writerInstanceId": { "type": "string", "minLength": 1 },
        "writerGeneration": { "type": "integer", "minimum": 1 },
        "startedUtc": { "type": "string" },
        "updatedUtc": { "type": "string" },
        "heartbeatUtc": { "type": "string" },
        "leaseTimeoutMs": { "type": "integer", "minimum": 1 },
        "leaseExpiresUtc": { "type": "string" },
        "daemonProcessId": { "type": "integer", "minimum": 0 },
        "daemonInstanceId": { "type": "string" },
        "daemonStartedUtc": { "type": "string" },
        "daemonHeartbeatUtc": { "type": "string" },
        "controlEndpoint": { "type": "string" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "ownerKind": { "const": "persistent-daemon" }
            },
            "required": ["ownerKind"]
          },
          "then": {
            "required": [
              "daemonProcessId",
              "daemonInstanceId",
              "daemonStartedUtc",
              "daemonHeartbeatUtc",
              "controlEndpoint"
            ],
            "properties": {
              "daemonProcessId": { "type": "integer", "minimum": 1 },
              "daemonInstanceId": { "type": "string", "minLength": 1 },
              "daemonStartedUtc": { "type": "string", "minLength": 1 },
              "daemonHeartbeatUtc": { "type": "string", "minLength": 1 },
              "controlEndpoint": { "type": "string", "minLength": 1 }
            }
          }
        }
      ]
    },
    "checkpoint": {
      "type": "object",
      "required": [
        "lastCommittedChunkSequence",
        "lastCommittedBatchSequence",
        "lastCommittedRecordSequence",
        "lastCommittedEventId",
        "lastManifestUpdateUtc",
        "lastIndexUpdateUtc",
        "indexConsistent"
      ],
      "properties": {
        "lastCommittedChunkSequence": { "type": "integer", "minimum": 0 },
        "lastCommittedBatchSequence": { "type": "integer", "minimum": 0 },
        "lastCommittedRecordSequence": { "type": "integer", "minimum": 0 },
        "lastCommittedEventId": { "type": "integer", "minimum": 0 },
        "lastManifestUpdateUtc": { "type": "string" },
        "lastIndexUpdateUtc": { "type": "string" },
        "indexConsistent": { "type": "boolean" }
      }
    },
    "recovery": {
      "type": "object",
      "required": [
        "state",
        "reason",
        "action",
        "classifiedUtc",
        "ownerAlive",
        "helperAlive",
        "writerAlive",
        "targetAlive",
        "leaseExpired",
        "restartEligible"
      ],
      "properties": {
        "state": { "enum": ["none", "owned", "stale", "recovery_required", "recovered", "abandoned", "malformed", "legacy"] },
        "reason": { "type": "string", "minLength": 1 },
        "action": { "enum": ["none", "wait", "replay_only", "recover_writer", "mark_abandoned", "manual_inspection"] },
        "classifiedUtc": { "type": "string" },
        "ownerAlive": { "type": "boolean" },
        "helperAlive": { "type": "boolean" },
        "writerAlive": { "type": "boolean" },
        "targetAlive": { "type": "boolean" },
        "leaseExpired": { "type": "boolean" },
        "restartEligible": { "type": "boolean" }
      }
    },
    "files": {
      "type": "object",
      "required": ["audit", "agentEvents", "index", "chunkDirectory"],
      "properties": {
        "audit": { "const": "audit.jsonl" },
        "agentEvents": { "const": "agent-events.jsonl" },
        "index": { "const": "index.json" },
        "chunkDirectory": { "const": "chunks" }
      }
    }
  }
}
