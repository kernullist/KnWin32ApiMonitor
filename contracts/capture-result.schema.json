{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kernullist.local/knmon/capture-result.schema.json",
  "title": "KnMonCaptureResult",
  "type": "object",
  "required": [
    "schemaVersion",
    "operationId",
    "success",
    "backendMode",
    "captureMode",
    "injectionMethod",
    "targetPath",
    "agentPath",
    "targetProcessId",
    "targetThreadId",
    "architecture",
    "win32ErrorCode",
    "ntStatus",
    "subsystem",
    "operation",
    "message",
    "droppedEvents",
    "transportMode",
    "transportCapacity",
    "transportRecordsProduced",
    "transportRecordsConsumed",
    "transportDroppedEvents",
    "transportHighWaterMark",
    "hookOverheadMinUs",
    "hookOverheadAvgUs",
    "hookOverheadMaxUs",
    "handshake",
    "auditEvents",
    "agentMessages",
    "capturedEvents"
  ],
  "properties": {
    "schemaVersion": { "type": "string" },
    "operationId": { "type": "string" },
    "success": { "type": "boolean" },
    "backendMode": { "enum": ["native-capture"] },
    "captureMode": { "enum": ["bounded-native-capture", "bounded-native-attach"] },
    "injectionMethod": { "enum": ["early-bird APC", "remote LoadLibraryW"] },
    "targetPath": { "type": "string" },
    "agentPath": { "type": "string" },
    "targetProcessId": { "type": "integer", "minimum": 0 },
    "attachProcessId": { "type": "integer", "minimum": 0 },
    "targetThreadId": { "type": "integer", "minimum": 0 },
    "attachState": {
      "enum": [
        "",
        "not_loaded",
        "loaded_disabled",
        "loaded_active",
        "loaded_busy",
        "loaded_incompatible",
        "loaded_unknown"
      ]
    },
    "attachStrategy": {
      "enum": [
        "",
        "load_library_initialize",
        "loaded_agent_reinitialize",
        "reject_already_active",
        "reject_incompatible",
        "reject_unknown"
      ]
    },
    "loadedAgentDetected": { "type": "boolean" },
    "loadedAgentModuleBase": { "type": "integer", "minimum": 0 },
    "loadedAgentPath": { "type": "string" },
    "agentControlStatus": { "type": "integer", "minimum": 0 },
    "agentAbiVersion": { "type": "integer", "minimum": 0 },
    "architecture": { "enum": ["x86", "x64"] },
    "win32ErrorCode": { "type": "integer", "minimum": 0 },
    "ntStatus": { "type": "string" },
    "subsystem": { "type": "string" },
    "operation": { "type": "string" },
    "message": { "type": "string" },
    "detachPolicy": { "type": "string" },
    "droppedEvents": { "type": "integer", "minimum": 0 },
    "transportMode": { "enum": ["named-pipe-json", "shared-memory"] },
    "transportCapacity": { "type": "integer", "minimum": 0 },
    "transportRecordsProduced": { "type": "integer", "minimum": 0 },
    "transportRecordsConsumed": { "type": "integer", "minimum": 0 },
    "transportDroppedEvents": { "type": "integer", "minimum": 0 },
    "transportHighWaterMark": { "type": "integer", "minimum": 0 },
    "hookOverheadMinUs": { "type": "integer", "minimum": 0 },
    "hookOverheadAvgUs": { "type": "integer", "minimum": 0 },
    "hookOverheadMaxUs": { "type": "integer", "minimum": 0 },
    "handshake": { "$ref": "agent-handshake.schema.json" },
    "auditEvents": {
      "type": "array",
      "items": { "$ref": "audit-event.schema.json" }
    },
    "agentMessages": {
      "type": "array",
      "items": { "$ref": "agent-event.schema.json" }
    },
    "capturedEvents": {
      "type": "array",
      "items": { "$ref": "agent-event.schema.json" }
    },
    "session": { "$ref": "session-info.schema.json" }
  }
}
