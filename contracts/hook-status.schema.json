{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kernullist.local/knmon/hook-status.schema.json",
  "title": "KnMonHookStatus",
  "type": "object",
  "required": [
    "schemaVersion",
    "messageType",
    "operationId",
    "pid",
    "tid",
    "timestampUtc",
    "sequence",
    "api",
    "module",
    "hookMethod",
    "message"
  ],
  "properties": {
    "schemaVersion": { "type": "string" },
    "messageType": {
      "enum": ["hook_installed", "hook_install_failed"]
    },
    "operationId": { "type": "string" },
    "pid": { "type": "integer", "minimum": 0 },
    "tid": { "type": "integer", "minimum": 0 },
    "timestampUtc": { "type": "string" },
    "sequence": { "type": "integer", "minimum": 0 },
    "api": { "type": "string" },
    "module": { "type": "string" },
    "hookMethod": { "enum": ["iat"] },
    "message": { "type": "string" }
  }
}
