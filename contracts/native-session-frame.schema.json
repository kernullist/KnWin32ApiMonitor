{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kernullist.local/knmon/native-session-frame.schema.json",
  "title": "KnMonNativeSessionFrame",
  "oneOf": [
    {
      "type": "object",
      "required": ["schemaVersion", "frameType", "session"],
      "properties": {
        "schemaVersion": { "type": "string" },
        "frameType": {
          "enum": [
            "session_started",
            "session_state",
            "session_stopping",
            "session_stopped",
            "session_failed"
          ]
        },
        "session": { "$ref": "native-session.schema.json" }
      }
    },
    {
      "$ref": "native-trace-batch.schema.json"
    },
    {
      "type": "object",
      "required": ["schemaVersion", "frameType", "session", "captureResult"],
      "properties": {
        "schemaVersion": { "type": "string" },
        "frameType": { "const": "capture_result" },
        "session": { "$ref": "native-session.schema.json" },
        "captureResult": { "$ref": "capture-result.schema.json" }
      }
    }
  ]
}
