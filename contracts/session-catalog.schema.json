{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kernullist.local/knmon/session-catalog.schema.json",
  "title": "KnMonSessionCatalog",
  "type": "object",
  "required": [
    "schemaVersion",
    "format",
    "buildTimeUtc",
    "backendMode",
    "operation",
    "success",
    "sessionCount",
    "sessions",
    "message"
  ],
  "properties": {
    "schemaVersion": { "type": "string" },
    "format": { "const": "knapm-session-catalog" },
    "buildTimeUtc": { "type": "string" },
    "backendMode": { "enum": ["native-capture"] },
    "operation": { "enum": ["catalog-sessions", "catalog-query", "catalog-remove-missing"] },
    "success": { "type": "boolean" },
    "rootPath": { "type": "string" },
    "catalogPath": { "type": "string" },
    "sessionCount": { "type": "integer", "minimum": 0 },
    "validSessionCount": { "type": "integer", "minimum": 0 },
    "invalidSessionCount": { "type": "integer", "minimum": 0 },
    "storedBytes": { "type": "integer", "minimum": 0 },
    "uncompressedBytes": { "type": "integer", "minimum": 0 },
    "dryRun": { "type": "boolean" },
    "mutationAttempted": { "type": "boolean" },
    "missingSessionPaths": {
      "type": "array",
      "items": { "type": "string" }
    },
    "sessions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "format",
          "sessionId",
          "operationId",
          "targetProcessId",
          "writerState",
          "finalized",
          "recoveryState",
          "recoveryReason",
          "recoveryAction",
          "chunkCount",
          "traceEventCount",
          "compression",
          "storedBytes",
          "uncompressedBytes",
          "validationSuccess",
          "validationErrorCount",
          "validationStatus",
          "lastValidatedUtc",
          "contentIdentity",
          "staleIdentity"
        ],
        "properties": {
          "path": { "type": "string" },
          "format": { "type": "string" },
          "sessionId": { "type": "string" },
          "operationId": { "type": "string" },
          "targetProcessId": { "type": "integer", "minimum": 0 },
          "targetImage": { "type": "string" },
          "targetPath": { "type": "string" },
          "targetArchitecture": { "type": "string" },
          "ownerKind": { "type": "string" },
          "daemonInstanceId": { "type": "string" },
          "writerState": { "type": "string" },
          "finalized": { "type": "boolean" },
          "recoveryState": { "type": "string" },
          "recoveryReason": { "type": "string" },
          "recoveryAction": { "type": "string" },
          "chunkCount": { "type": "integer", "minimum": 0 },
          "traceEventCount": { "type": "integer", "minimum": 0 },
          "lastBatchSequence": { "type": "integer", "minimum": 0 },
          "lastRecordSequence": { "type": "integer", "minimum": 0 },
          "compression": { "type": "string" },
          "storedBytes": { "type": "integer", "minimum": 0 },
          "uncompressedBytes": { "type": "integer", "minimum": 0 },
          "validationSuccess": { "type": "boolean" },
          "validationErrorCount": { "type": "integer", "minimum": 0 },
          "validationStatus": { "enum": ["valid", "invalid"] },
          "lastValidatedUtc": { "type": "string" },
          "contentIdentity": { "type": "string" },
          "staleIdentity": { "type": "boolean" }
        }
      }
    },
    "message": { "type": "string" }
  }
}
