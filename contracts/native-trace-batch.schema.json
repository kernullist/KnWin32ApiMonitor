{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kernullist.local/knmon/native-trace-batch.schema.json",
  "title": "KnMonNativeTraceBatch",
  "type": "object",
  "required": [
    "schemaVersion",
    "frameType",
    "sessionId",
    "operationId",
    "batchSequence",
    "firstRecordSequence",
    "lastRecordSequence",
    "eventCount",
    "droppedEvents",
    "recordsStreamed",
    "hostDroppedBatches",
    "events"
  ],
  "properties": {
    "schemaVersion": { "type": "string" },
    "frameType": { "const": "trace_batch" },
    "sessionId": { "type": "string" },
    "operationId": { "type": "string" },
    "batchSequence": { "type": "integer", "minimum": 1 },
    "firstRecordSequence": { "type": "integer", "minimum": 0 },
    "lastRecordSequence": { "type": "integer", "minimum": 0 },
    "eventCount": { "type": "integer", "minimum": 0 },
    "droppedEvents": { "type": "integer", "minimum": 0 },
    "recordsStreamed": { "type": "integer", "minimum": 0 },
    "hostDroppedBatches": { "type": "integer", "minimum": 0 },
    "events": {
      "type": "array",
      "items": { "$ref": "agent-event.schema.json" }
    }
  }
}
