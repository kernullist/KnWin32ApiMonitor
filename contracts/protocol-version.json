{
  "name": "KnMonProtocolVersion",
  "major": 0,
  "minor": 1,
  "patch": 0,
  "schemaVersion": "0.1.0",
  "nativeCaptureFoundation": {
    "backendModes": ["mock", "native-enum", "native-capture"],
    "injectionMethods": ["early-bird APC", "remote LoadLibraryW"],
    "agentArchitectures": ["x64", "x86"],
    "controlledLaunchOnly": false,
    "sameBitnessOnly": true,
    "preflightChecks": ["target_binary", "agent_binary", "helper_architecture", "target_architecture", "agent_architecture"]
  },
  "runningProcessAttach": {
    "captureMode": "bounded-native-attach",
    "injectionMethod": "remote LoadLibraryW",
    "attachConfigAbiVersion": 1,
    "detachPolicy": "self-disable-no-unload",
    "sameBitnessOnly": true,
    "supportedTargets": ["non_protected_user_mode_process"],
    "preflightChecks": ["target_process_exists", "target_architecture", "helper_target_architecture_match", "agent_architecture", "helper_agent_architecture_match", "protected_process_detection", "mutation_handle_access"]
  },
  "liveFileIoCapture": {
    "captureMode": "bounded-native-capture",
    "hookMethod": "iat",
    "controlledSampleOnly": true,
    "apiEventTransport": "shared-memory",
    "controlMessageTransport": "named-pipe-json",
    "hookedApis": ["CreateFileW", "CreateFileA", "NtCreateFile", "ReadFile", "WriteFile", "CloseHandle", "LoadLibraryW", "LoadLibraryA", "LoadLibraryExW", "LoadLibraryExA", "LdrLoadDll"],
    "hookedModules": ["kernel32.dll", "kernelbase.dll", "ntdll.dll"],
    "minimumRequiredHookCount": 6,
    "messageTypes": ["agent_hello", "hook_installed", "hook_install_failed", "api_call", "dropped_events", "agent_shutdown", "module_inventory", "iat_sweep"],
    "lifecycleStates": ["starting", "running", "stopping", "disabled", "failed"],
    "shutdownFields": ["reason", "lifecycleState", "installedHooks", "restoredHooks", "failedHooks", "droppedCount"]
  },
  "loaderAwareCoverage": {
    "moduleInventorySource": "PEB loader list snapshot",
    "patchOwnerPolicy": "eligible non-agent non-system modules",
    "providerModulesWave1": ["ntdll.dll", "kernelbase.dll", "kernel32.dll"],
    "dynamicLoadApis": ["LoadLibraryW", "LoadLibraryA", "LoadLibraryExW", "LoadLibraryExA", "LdrLoadDll"],
    "statusMessageTypes": ["module_inventory", "iat_sweep"],
    "dynamicProbe": "knmon-dynamic-probe.dll"
  },
  "sharedMemoryTransport": {
    "abiVersion": 1,
    "overflowPolicy": "drop-newest",
    "defaultCapacity": 1024,
    "hotPathPolicy": ["no_api_json_serialization", "no_blocking_pipe_write_for_api_events", "bounded_payloads"],
    "metricsFields": ["transportMode", "transportCapacity", "transportRecordsProduced", "transportRecordsConsumed", "transportDroppedEvents", "transportHighWaterMark", "hookOverheadMinUs", "hookOverheadAvgUs", "hookOverheadMaxUs"]
  },
  "sessionWriter": {
    "captureCommand": "capture-sample --write-session <dir>",
    "attachCaptureCommand": "attach-capture --pid <pid> --write-session <dir>",
    "validationCommand": "validate-session --session <dir>",
    "replayCommand": "replay-session --session <dir>",
    "files": ["manifest.json", "audit.jsonl", "agent-events.jsonl", "trace-events.jsonl"],
    "replayCaptureMode": "session-replay",
    "controlledSampleOnly": true
  },
  "collectorBackpressure": {
    "smokeCommand": "knmon-collector.exe smoke-backpressure --capacity 4 --events 10",
    "overflowPolicies": ["drop-newest"],
    "defaultSmokeCapacity": 4,
    "defaultSmokeEvents": 10,
    "statsFields": ["acceptedEvents", "drainedEvents", "droppedEvents", "queueDepth", "highWaterMark", "backpressureActivations"]
  }
}
