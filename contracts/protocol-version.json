{
  "name": "KnMonProtocolVersion",
  "major": 0,
  "minor": 1,
  "patch": 0,
  "schemaVersion": "0.1.0",
  "nativeCaptureFoundation": {
    "backendModes": ["mock", "native-enum", "native-capture"],
    "injectionMethods": ["early-bird APC", "remote LoadLibraryW"],
    "agentArchitectures": ["x64", "x86"],
    "controlledLaunchOnly": false,
    "sameBitnessOnly": true,
    "preflightChecks": ["target_binary", "agent_binary", "helper_architecture", "target_architecture", "agent_architecture"]
  },
  "runningProcessAttach": {
    "captureMode": "bounded-native-attach",
    "injectionMethod": "remote LoadLibraryW",
    "attachConfigAbiVersion": 1,
    "detachPolicy": "self-disable-no-unload",
    "sameBitnessOnly": true,
    "supportedTargets": ["non_protected_user_mode_process"],
    "preflightChecks": ["target_process_exists", "target_architecture", "helper_target_architecture_match", "agent_architecture", "helper_agent_architecture_match", "protected_process_detection", "mutation_handle_access"]
  },
  "processTreeSupervision": {
    "supervisionMode": "process-tree",
    "command": "supervise-tree --pid <pid> --duration-ms <ms> --child-policy <observe|attach-supported>",
    "childPolicies": ["observe", "attach-supported"],
    "eligibilityStatuses": ["eligible", "missing", "exited", "unknown_architecture", "helper_target_mismatch", "access_denied", "protected_process", "unsupported"],
    "policyDecisions": ["observe_only", "attach_allowed", "attach_skipped", "attach_failed", "unsupported"],
    "discoverySource": "Toolhelp process snapshots",
    "observePolicy": "no_remote_mutation",
    "attachSupportedPolicy": "reuse_phase_11a_attach_capture_for_same_bitness_repository_sample_children",
    "sameBitnessOnly": true,
    "supportedChildTargets": ["repository_sample_child_process"],
    "nonGoals": ["persistent_daemon", "kernel_process_notifications", "cross_bitness_attach", "protected_process_bypass"]
  },
  "liveFileIoCapture": {
    "captureMode": "bounded-native-capture",
    "hookMethod": "iat",
    "controlledSampleOnly": true,
    "apiEventTransport": "shared-memory",
    "controlMessageTransport": "named-pipe-json",
    "hookedApis": ["CreateFileW", "CreateFileA", "NtCreateFile", "ReadFile", "WriteFile", "CloseHandle", "LoadLibraryW", "LoadLibraryA", "LoadLibraryExW", "LoadLibraryExA", "LdrLoadDll"],
    "hookedModules": ["kernel32.dll", "kernelbase.dll", "ntdll.dll"],
    "minimumRequiredHookCount": 6,
    "messageTypes": ["agent_hello", "hook_installed", "hook_install_failed", "api_call", "dropped_events", "agent_shutdown", "module_inventory", "iat_sweep"],
    "lifecycleStates": ["starting", "running", "stopping", "disabled", "failed"],
    "shutdownFields": ["reason", "lifecycleState", "installedHooks", "restoredHooks", "failedHooks", "droppedCount"]
  },
  "loaderAwareCoverage": {
    "moduleInventorySource": "PEB loader list snapshot",
    "patchOwnerPolicy": "eligible non-agent non-system modules",
    "providerModulesWave1": ["ntdll.dll", "kernelbase.dll", "kernel32.dll"],
    "dynamicLoadApis": ["LoadLibraryW", "LoadLibraryA", "LoadLibraryExW", "LoadLibraryExA", "LdrLoadDll"],
    "statusMessageTypes": ["module_inventory", "iat_sweep"],
    "dynamicProbe": "knmon-dynamic-probe.dll"
  },
  "sharedMemoryTransport": {
    "abiVersion": 1,
    "overflowPolicy": "drop-newest",
    "defaultCapacity": 1024,
    "hotPathPolicy": ["no_api_json_serialization", "no_blocking_pipe_write_for_api_events", "bounded_payloads"],
    "metricsFields": ["transportMode", "transportCapacity", "transportRecordsProduced", "transportRecordsConsumed", "transportDroppedEvents", "transportHighWaterMark", "hookOverheadMinUs", "hookOverheadAvgUs", "hookOverheadMaxUs"]
  },
  "sessionWriter": {
    "captureCommand": "capture-sample --write-session <dir>",
    "attachCaptureCommand": "attach-capture --pid <pid> --write-session <dir>",
    "streamingAttachKnapmCommand": "attach-session --pid <pid> --stream-batches --write-knapm <path.knapm> [--knapm-compression none|zstd]",
    "daemonKnapmCommand": "daemon-start-session --pid <pid> --write-knapm <path.knapm> [--knapm-compression none|zstd]",
    "validationCommand": "validate-session --session <dir-or-knapm>",
    "replayCommand": "replay-session --session <dir-or-knapm>",
    "catalogCommands": [
      "catalog-sessions --root <dir> [--catalog <path>] [--rebuild]",
      "catalog-query --catalog <path> [--limit n] [--state state] [--target pid-or-text]",
      "catalog-remove-missing --catalog <path> [--dry-run]",
      "catalog-index-build --root <dir> --database <path> [--rebuild]",
      "catalog-index-query --database <path> [--limit n] [--state state] [--target pid-or-text]",
      "catalog-index-remove-missing --database <path> [--dry-run]"
    ],
    "catalogIndexBackend": "winsqlite3",
    "catalogIndexSchemaVersion": 1,
    "catalogIndexBoundary": "Phase 13A stores host-side .knapm metadata rows only; raw trace payload indexing and target mutation are out of scope.",
    "files": ["manifest.json", "audit.jsonl", "agent-events.jsonl", "trace-events.jsonl"],
    "knapmFiles": ["manifest.json", "index.json", "audit.jsonl", "agent-events.jsonl", "chunks/trace-000001.jsonl", "chunks/trace-000001.jsonl.zst"],
    "knapmManifestSchema": "knapm-manifest.schema.json",
    "knapmIndexSchema": "knapm-index.schema.json",
    "knapmCatalogSchema": "session-catalog.schema.json",
    "knapmCompression": ["none", "zstd"],
    "knapmCompressionIntegrityFields": ["byteLength", "sha256", "uncompressedByteLength", "uncompressedSha256"],
    "knapmUnsupportedCompressionError": "unsupported_compression",
    "knapmZstdBoundary": "Phase 11M writes standards-compatible zstd raw-block frames without adding a target hot-path compression dependency.",
    "knapmChunkBoundary": "one finalized chunk per non-empty trace_batch frame",
    "knapmOwnershipSections": ["owner", "checkpoint", "recovery"],
    "knapmOwnerKinds": ["bounded-helper", "persistent-daemon"],
    "knapmRecoveryStates": ["none", "owned", "stale", "recovery_required", "recovered", "abandoned", "malformed", "legacy"],
    "knapmRecoveryActions": ["none", "wait", "replay_only", "recover_writer", "mark_abandoned", "manual_inspection"],
    "knapmRecoveryBoundary": "Phase 11J classifies ownership and restart eligibility without target mutation; automatic daemon crash recovery remains future work",
    "persistentDaemonFoundation": {
      "phase": "11N",
      "commands": ["daemon-start", "daemon-status", "daemon-audit", "daemon-recovery-plan", "daemon-recovery-apply", "daemon-prune-stale", "daemon-start-session", "daemon-list-sessions", "daemon-stop-session", "daemon-stop"],
      "ownerKind": "persistent-daemon",
      "controlEndpoint": "file-registry",
      "daemonStatusSchema": "native-daemon-status.schema.json",
      "daemonAuditSchema": "native-daemon-audit.schema.json",
      "daemonRecoveryPlanSchema": "native-daemon-recovery-plan.schema.json",
      "daemonRecoveryApplySchema": "native-daemon-recovery-apply.schema.json",
      "auditStates": ["healthy", "finalized", "stale", "daemon_crashed", "writer_crashed", "orphaned_agent_risk", "malformed"],
      "recoveryPlanBoundary": "daemon-recovery-plan is dry-run only and reports operator runbook steps; it does not recover writers, unload agents, kill targets, reinject, delete .knapm data, or mutate target processes",
      "recoveryApplyBoundary": "daemon-recovery-apply is dry-run by default and can only remove registry records already marked registryPruneAllowed when --apply-registry-prune is explicitly provided",
      "duplicateStartRejections": ["already_supervised", "session_id_in_use", "knapm_path_in_use", "stale_registry_requires_prune"],
      "staleRegistryPruneBoundary": "daemon-prune-stale removes only daemon registry records classified pruneEligible; it does not delete .knapm data, recover writers, unload agents, or mutate target processes",
      "serviceMode": false,
      "crashRecovery": false,
      "sameBitnessOnly": true
    },
    "replayCaptureMode": "session-replay",
    "controlledSampleOnly": true
  },
  "nativeStreamingSession": {
    "command": "attach-session --pid <pid> --stream-batches --batch-size <n> --batch-interval-ms <n>",
    "frameTypes": ["session_started", "session_state", "trace_batch", "session_stopping", "session_stopped", "session_failed", "capture_result"],
    "traceBatchSchema": "native-trace-batch.schema.json",
    "sessionFrameSchema": "native-session-frame.schema.json",
    "batchBoundary": "contiguous trace_batch batchSequence values",
    "recordBoundary": "monotonic firstRecordSequence and lastRecordSequence for non-empty batches",
    "hotPathPolicy": "host_side_batching_only",
    "hostDropAccounting": "hostDroppedBatches is separate from target transport dropped records",
    "nonGoals": ["persistent_daemon", "dll_unload", "cross_bitness_attach", "protected_process_bypass"]
  },
  "collectorBackpressure": {
    "smokeCommand": "knmon-collector.exe smoke-backpressure --capacity 4 --events 10",
    "overflowPolicies": ["drop-newest"],
    "defaultSmokeCapacity": 4,
    "defaultSmokeEvents": 10,
    "statsFields": ["acceptedEvents", "drainedEvents", "droppedEvents", "queueDepth", "highWaterMark", "backpressureActivations"]
  }
}
