{
  "name": "kn-win32apimon",
  "version": "0.1.0",
  "private": true,
  "description": "Modern Win32 API monitor workstation foundation.",
  "workspaces": [
    "apps/knmon-ui"
  ],
  "scripts": {
    "dev": "npm --workspace apps/knmon-ui run dev",
    "build": "npm --workspace apps/knmon-ui run build",
    "preview": "npm --workspace apps/knmon-ui run preview",
    "tauri:dev": "npm --workspace apps/knmon-ui run tauri:dev",
    "tauri:build": "npm --workspace apps/knmon-ui run tauri:build",
    "native:configure": "cmake -S native -B build/native",
    "native:build": "cmake --build build/native --config Debug",
    "defs:generate": "node tools/def-validator/generate-definition-ids.mjs --write",
    "defs:coverage": "node tools/def-validator/report-definition-coverage.mjs",
    "defs:decoder-tables": "node tools/def-validator/validate-generated-decoder-tables.mjs",
    "defs:validate": "node tools/def-validator/validate-definitions.mjs && npm run defs:decoder-tables && node tools/rohitab-importer/test-importer.mjs && node tools/def-validator/report-definition-coverage.mjs --check",
    "ui:validate": "node tools/ui-validator/validate-virtual-trace-window.mjs && node tools/ui-validator/validate-trace-query.mjs",
    "sessions:validate": "node tools/session-validator/validate-session-fixtures.mjs",
    "collector:validate": "node tools/collector-validator/validate-collector-fixtures.mjs",
    "verify": "npm run build && npm run ui:validate && npm run defs:validate && npm run sessions:validate && npm run collector:validate"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "ajv": "^8.20.0"
  }
}
