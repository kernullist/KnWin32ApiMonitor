{
  "name": "kn-win32apimon",
  "version": "0.1.0",
  "private": true,
  "description": "Modern Win32 API monitor workstation foundation.",
  "workspaces": [
    "apps/knmon-ui"
  ],
  "scripts": {
    "dev": "npm --workspace apps/knmon-ui run dev",
    "build": "npm --workspace apps/knmon-ui run build",
    "preview": "npm --workspace apps/knmon-ui run preview",
    "tauri:dev": "npm --workspace apps/knmon-ui run tauri:dev",
    "tauri:build": "npm --workspace apps/knmon-ui run tauri:build",
    "native:configure": "cmake -S native -B build/native",
    "native:build": "cmake --build build/native --config Debug",
    "daemon-recovery-plan:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/native-smoke/daemon-recovery-plan-smoke.ps1",
    "daemon-recovery-apply:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/native-smoke/daemon-recovery-apply-smoke.ps1",
    "catalog-index:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/native-smoke/catalog-index-smoke.ps1",
    "trace-index:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/native-smoke/trace-index-smoke.ps1",
    "wave2-rpcrt4-endpoint:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/native-smoke/wave2-rpcrt4-endpoint-inquiry-cleanup-smoke.ps1",
    "wave4-oleaut32:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/native-smoke/wave4-oleaut32-lifecycle-smoke.ps1",
    "wave4-secur32:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/native-smoke/wave4-secur32-credential-free-smoke.ps1",
    "wave4-dnsapi:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/native-smoke/wave4-dnsapi-record-free-smoke.ps1",
    "wave4-setupapi:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/native-smoke/wave4-setupapi-device-info-close-smoke.ps1",
    "wave4-userenv:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/native-smoke/wave4-userenv-environment-block-destroy-smoke.ps1",
    "wave4-iphlpapi:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/native-smoke/wave4-iphlpapi-interface-entry-smoke.ps1",
    "wave4-wintrust:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/native-smoke/wave4-wintrust-state-query-smoke.ps1",
    "wave4-dbghelp:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/native-smoke/wave4-dbghelp-symbol-session-smoke.ps1",
    "tier1-generic:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/native-smoke/tier1-generic-profile-smoke.ps1",
    "tier2-generic:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/native-smoke/tier2-generic-profile-smoke.ps1",
    "defs:generate": "node tools/def-validator/generate-definition-ids.mjs --write",
    "defs:phnt-prototypes": "node tools/def-validator/generate-phnt-ntdll-prototype-index.mjs --write",
    "defs:ntdll-sdk-prototypes": "node tools/def-validator/generate-ntdll-sdk-prototype-index.mjs --write",
    "defs:ntdll-supplemental-spec": "node tools/def-validator/generate-ntdll-supplemental-spec-index.mjs --write",
    "defs:ntdll-latest-overlay": "node tools/def-validator/generate-ntdll-latest-export-overlay.mjs --write",
    "defs:bulk-expansion": "node tools/def-validator/generate-bulk-monitoring-definitions.mjs --write --target-defined=30000",
    "defs:inventory": "node tools/def-validator/generate-api-inventory.mjs --write",
    "defs:inventory:check": "node tools/def-validator/generate-api-inventory.mjs --check",
    "defs:inventory:validate": "node tools/def-validator/validate-api-inventory.mjs",
    "defs:tier1-plan:generate": "node tools/def-validator/generate-tier1-hook-plan.mjs --write",
    "defs:tier1-plan:check": "node tools/def-validator/generate-tier1-hook-plan.mjs --check",
    "defs:tier1-plan": "node tools/def-validator/validate-tier1-hook-plan.mjs",
    "defs:tier1-plan:select": "node tools/def-validator/plan-tier1-hooks.mjs",
    "defs:tier2-plan:generate": "node tools/def-validator/generate-tier2-hook-plan.mjs --write",
    "defs:tier2-plan:check": "node tools/def-validator/generate-tier2-hook-plan.mjs --check",
    "defs:tier2-plan": "node tools/def-validator/validate-tier2-hook-plan.mjs",
    "defs:tier2-plan:select": "node tools/def-validator/plan-tier2-hooks.mjs",
    "defs:tier2-profile-batch-plan:generate": "node tools/def-validator/generate-tier2-profile-batch-plan.mjs --write",
    "defs:tier2-profile-batch-plan:check": "node tools/def-validator/generate-tier2-profile-batch-plan.mjs --check",
    "defs:tier2-profile-batch-plan": "node tools/def-validator/validate-tier2-profile-batch-plan.mjs",
    "defs:tier2-profile-batch-plan:select": "node tools/def-validator/plan-tier2-profile-batches.mjs",
    "defs:tier2-profile-review:generate": "node tools/def-validator/generate-tier2-profile-review-manifest.mjs --write",
    "defs:tier2-profile-review:check": "node tools/def-validator/generate-tier2-profile-review-manifest.mjs --check",
    "defs:tier2-profile-review": "node tools/def-validator/validate-tier2-profile-review-manifest.mjs",
    "defs:tier3-plan:generate": "node tools/def-validator/generate-tier3-hook-plan.mjs --write",
    "defs:tier3-plan:check": "node tools/def-validator/generate-tier3-hook-plan.mjs --check",
    "defs:tier3-plan": "node tools/def-validator/validate-tier3-hook-plan.mjs",
    "defs:tier3-plan:select": "node tools/def-validator/plan-tier3-hooks.mjs",
    "defs:dll-batch-plan:generate": "node tools/def-validator/generate-dll-batch-promotion-plan.mjs --write",
    "defs:dll-batch-plan:check": "node tools/def-validator/generate-dll-batch-promotion-plan.mjs --check",
    "defs:dll-batch-plan": "node tools/def-validator/validate-dll-batch-promotion-plan.mjs",
    "defs:manual-decoder-plan:generate": "node tools/def-validator/generate-manual-decoder-batch-plan.mjs --write",
    "defs:manual-decoder-plan:check": "node tools/def-validator/generate-manual-decoder-batch-plan.mjs --check",
    "defs:manual-decoder-plan": "node tools/def-validator/validate-manual-decoder-batch-plan.mjs",
    "defs:coverage": "node tools/def-validator/report-definition-coverage.mjs",
    "defs:decoder-tables": "node tools/def-validator/validate-generated-decoder-tables.mjs",
    "agent-hooks:generate": "node tools/def-validator/generate-agent-hook-definitions.mjs --write",
    "agent-hooks:check": "node tools/def-validator/generate-agent-hook-definitions.mjs --check",
    "defs:validate": "node tools/def-validator/validate-definitions.mjs && npm run defs:decoder-tables && npm run defs:inventory:validate && npm run defs:tier1-plan:check && npm run defs:tier1-plan && npm run defs:tier2-plan:check && npm run defs:tier2-plan && npm run defs:tier2-profile-batch-plan:check && npm run defs:tier2-profile-batch-plan && npm run defs:tier2-profile-review:check && npm run defs:tier2-profile-review && npm run defs:tier3-plan:check && npm run defs:tier3-plan && npm run defs:dll-batch-plan:check && npm run defs:dll-batch-plan && npm run defs:manual-decoder-plan:check && npm run defs:manual-decoder-plan && npm run agent-hooks:check && node tools/rohitab-importer/test-importer.mjs && node tools/def-validator/report-definition-coverage.mjs --check",
    "ui:validate": "node tools/ui-validator/validate-virtual-trace-window.mjs && node tools/ui-validator/validate-trace-query.mjs && node tools/ui-validator/validate-trace-views.mjs && node tools/ui-validator/validate-trace-highlights.mjs",
    "sessions:validate": "node tools/session-validator/validate-session-fixtures.mjs",
    "collector:validate": "node tools/collector-validator/validate-collector-fixtures.mjs",
    "verify": "npm run build && npm run ui:validate && npm run defs:validate && npm run sessions:validate && npm run collector:validate"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "ajv": "^8.20.0"
  }
}
